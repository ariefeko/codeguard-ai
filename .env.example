# GitHub
GITHUB_PAT_TOKEN=your-fine-grained-token
GITHUB_WEBHOOK_SECRET=your-webhook-secret
CODEGUARD_ALLOWED_REPOS=owner/repository
CODEGUARD_STATUS_TARGET_URL=

# Redis / RQ
REDIS_URL=redis://localhost:6379
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5
REDIS_SOCKET_TIMEOUT_SECONDS=5
REDIS_RETRY_ATTEMPTS=3
REDIS_RETRY_BASE_DELAY_SECONDS=0.1
REDIS_RETRY_MAX_DELAY_SECONDS=2

# LLM provider chain (configure at least one)
OPENAGENTIC_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=

# Sentry
SENTRY_CLIENT_SECRET=
CODEGUARD_DEFAULT_OWNER=owner
CODEGUARD_DEFAULT_REPO=repository
CODEGUARD_DEFAULT_BRANCH=main
SENTRY_DEDUP_PENDING_TTL_SECONDS=60

# Optional curated RAG / Qdrant
RAG_ENABLED=false
QDRANT_URL=
QDRANT_API_KEY=
RAG_MAX_RESULTS=5
RAG_MIN_CONFIDENCE=0.65

# HTTP tuning
HTTP_REQUEST_TIMEOUT_SECONDS=10
LLM_REQUEST_TIMEOUT_SECONDS=60
QDRANT_SYNC_TIMEOUT_SECONDS=30
GITHUB_RETRY_MAX_ATTEMPTS=3
GITHUB_RETRY_BASE_DELAY_SECONDS=0.5
GITHUB_RETRY_MAX_DELAY_SECONDS=4

# Log completion metadata only; never logs raw LLM output.
DEBUG_LLM_OUTPUT=0
